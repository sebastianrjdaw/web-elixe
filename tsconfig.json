{
    "compilerOptions": {
        "allowJs": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "target": "ES2020",
        "types": ["vite/client"],
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "vite.config.js"]
}
